    {
      "parameters": {
        "jsCode": "// Generate personalized 2-second follow-up message based on summary\nconst items = $input.all();\nconst outputs = [];\n\nfor (const item of items) {\n  const summary = item.json.Summary || '';\n  const name = item.json.Name || 'there';\n  const phone = item.json.Phone;\n  const recordId = item.json.id;\n  \n  let message = '';\n  \n  // Analyze summary and create contextual message\n  if (summary.toLowerCase().includes('price') || summary.toLowerCase().includes('cost')) {\n    message = `Hi ${name}! 👋\\n\\nI noticed you were interested in our pricing. I wanted to follow up and see if you had any questions about our packages or payment plans?\\n\\nWe have some flexible options that might work perfectly for you. Would you like me to share more details?`;\n  } \n  else if (summary.toLowerCase().includes('ipollo') || summary.toLowerCase().includes('miner') || summary.toLowerCase().includes('device')) {\n    message = `Hi ${name}! 👋\\n\\nFollowing up on your interest in our mining equipment. Did you have any specific questions about the device specifications, profitability, or setup process?\\n\\nI'm here to help you make the best decision for your mining needs!`;\n  }\n  else if (summary.toLowerCase().includes('egypt') || summary.toLowerCase().includes('location') || summary.toLowerCase().includes('shipping')) {\n    message = `Hi ${name}! 👋\\n\\nJust checking in regarding your inquiry. We do handle international shipping and can discuss delivery options for your location.\\n\\nWould you like to know more about shipping costs and timelines?`;\n  }\n  else if (summary.toLowerCase().includes('service') || summary.toLowerCase().includes('interested')) {\n    message = `Hi ${name}! 👋\\n\\nThanks for your interest in our services! I wanted to follow up and see if you had any questions or needed more information.\\n\\nI'm happy to provide any details that would help with your decision. What would be most helpful for you?`;\n  }\n  else if (summary.toLowerCase().includes('facebook') || summary.toLowerCase().includes('social')) {\n    message = `Hi ${name}! 👋\\n\\nThanks for reaching out! I wanted to follow up on your inquiry. How can I assist you with your crypto mining needs today?\\n\\nFeel free to ask me anything about our products, services, or mining in general!`;\n  }\n  else {\n    // Generic follow-up for unclear summaries\n    message = `Hi ${name}! 👋\\n\\nI wanted to check in and see if you had any questions about crypto mining or our services.\\n\\nI'm here to help! What information would be most valuable for you right now?`;\n  }\n  \n  outputs.push({\n    json: {\n      phone: phone,\n      message: message,\n      name: name,\n      summary: summary,\n      recordId: recordId\n    }\n  });\n}\n\nreturn outputs;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
