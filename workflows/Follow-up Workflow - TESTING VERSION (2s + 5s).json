    {
      "parameters": {
        "jsCode": "// Generate 5-second continuation follow-up\nconst items = $input.all();\nconst outputs = [];\n\nfor (const item of items) {\n  const summary = item.json.Summary || '';\n  const name = item.json.Name || 'there';\n  const phone = item.json.Phone;\n  const recordId = item.json.id;\n  \n  let message = '';\n  \n  // Create continuation message based on initial interest\n  if (summary.toLowerCase().includes('price') || summary.toLowerCase().includes('cost')) {\n    message = `Hi ${name},\\n\\nI wanted to share something that might interest you! 💎\\n\\nWe're currently offering special payment plans that make it easier to get started with crypto mining. Many of our clients have found these flexible options really helpful.\\n\\nWould you like me to explain the options? No pressure at all - just want to make sure you have all the information you need!`;\n  } \n  else if (summary.toLowerCase().includes('ipollo') || summary.toLowerCase().includes('miner') || summary.toLowerCase().includes('device')) {\n    message = `Hi ${name},\\n\\nQuick update! ⛏️\\n\\nI wanted to share that we have detailed profitability calculators and setup guides that show exactly what you can expect from our miners.\\n\\nWould you like me to send you some real-world examples from our current clients? It might help you visualize the potential returns!`;\n  }\n  else if (summary.toLowerCase().includes('egypt') || summary.toLowerCase().includes('location') || summary.toLowerCase().includes('shipping')) {\n    message = `Hi ${name},\\n\\nI wanted to follow up with good news! 🌍\\n\\nWe've successfully shipped to many international locations and have streamlined the process. I can provide you with estimated shipping costs and delivery times specific to your location.\\n\\nShould I prepare that information for you?`;\n  }\n  else {\n    // Generic 5-second follow-up\n    message = `Hi ${name},\\n\\nI hope I'm not bothering you! I just wanted to make sure you have everything you need to make an informed decision about crypto mining.\\n\\nIf you have any questions at all - even if they seem basic - I'm here to help. Sometimes the smallest questions lead to the best clarity! 😊\\n\\nWhat can I help you with?`;\n  }\n  \n  outputs.push({\n    json: {\n      phone: phone,\n      message: message,\n      name: name,\n      summary: summary,\n      recordId: recordId\n    }\n  });\n}\n\nreturn outputs;"
      },
