    {
      "parameters": {
        "jsCode": "// 1. Get the raw output (Could be a String OR an Object)\nlet raw = $input.item.json.output;\n\n// 2. Normalize: If it's a string (Scenario A), parse it into an object first\nif (typeof raw === 'string') {\n    try {\n        // Clean markdown wrapper if present\n        raw = raw.replace(/```json/g, '').replace(/```/g, '').trim();\n        raw = JSON.parse(raw);\n    } catch (e) {\n        // If parsing fails, treat it as a text object\n        raw = { response_to_user: raw };\n    }\n}\n\n// 3. Extract the initial text (Scenario B)\n// If raw was null/undefined, default to empty object\nraw = raw || {};\nlet finalParams = raw.response_to_user || raw.text || raw.response || \"\";\n\n// 4. Double-Check: Is the extracted text actually HIDDEN JSON? (Scenario C - The \"Dirty\" case)\nif (typeof finalParams === 'string' && (finalParams.trim().startsWith('{') || finalParams.trim().startsWith('```'))) {\n    try {\n        const cleanRaw = finalParams.replace(/```json/g, '').replace(/```/g, '').trim();\n        const parsedDeep = JSON.parse(cleanRaw);\n        finalParams = parsedDeep.response_to_user || parsedDeep.text || finalParams;\n    } catch (e) {\n        // If deep parse fails, try regex to grab the value manually\n        const match = finalParams.match(/\"response_to_user\"\\s*:\\s*\"((?:[^\"\\\\]|\\\\.)*)\"/);\n        if (match) {\n            finalParams = match[1];\n        }\n    }\n}\n\n// 5. Final fallback: If empty, verify if we missed the text in a weird field\nif (!finalParams && typeof raw === 'string') {\n    finalParams = raw; \n}\n\nreturn {\n  json: {\n    output: {\n      response_to_user: finalParams\n    }\n  }\n};"
      },
